# MOIN BizPlus automation credentials (server-side only)
MOIN_BIZPLUS_LOGIN_ID=
MOIN_BIZPLUS_LOGIN_PASSWORD=

# Optional: set to "false" to run browser in non-headless mode for debugging
MOIN_BIZPLUS_HEADLESS=true

# Coupang consumer login for purchase-history scraping (optional; can be passed
# per-request via the admin UI instead of being stored here).
COUPANG_USER_LOGIN_ID=
COUPANG_USER_LOGIN_PASSWORD=
# Set to "false" to launch Chromium in non-headless mode (helps clear CAPTCHA).
COUPANG_USER_HEADLESS=true
# Outbound proxy for the Coupang scraper. Required on hosts (Vercel etc.) whose
# IP range is blocked by Coupang's Akamai WAF. The scraper also accepts
# QUOTAGUARDSTATIC_URL / FIXIE_URL / HTTPS_PROXY / HTTP_PROXY (in that order).
# Format: http://user:pass@host:port
COUPANG_USER_PROXY_URL=
