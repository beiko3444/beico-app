generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String          @id @default(uuid())
  username       String          @unique
  password       String
  name           String
  role           String          @default("PARTNER")
  status         String          @default("PENDING")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  country        String?
  orders         Order[]
  proformaInvoices ProformaInvoice[]
  partnerProfile PartnerProfile?
}

model PartnerProfile {
  id                      String  @id @default(uuid())
  userId                  String  @unique
  contact                 String?
  fax                     String?
  email                   String?
  businessName            String?
  representativeName      String?
  businessRegNumber       String?
  address                 String?
  businessRegistrationUrl String?
  grade                   String  @default("C")
  user                    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Product {
  id               String      @id @default(uuid())
  name             String
  nameJP           String?
  buyPrice         Float
  sellPrice        Float
  onlinePrice      Float?      @default(0)
  priceA           Float?
  priceB           Float?
  priceC           Float?
  priceD           Float?
  stock            Int         @default(0)
  safetyStock      Int         @default(0)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  barcode          String?
  productCode      String?
  coupangSku       String?     @unique
  imageUrl         String?
  sortOrder        Int         @default(0)
  minOrderQuantity Int         @default(1)
  nameEN           String?
  jpBuyPrice       Float?      @default(0)
  jpSellPrice      Float?      @default(0)
  krBuyPrice       Float?      @default(0)
  krSellPrice      Float?      @default(0)
  usBuyPrice       Float?      @default(0)
  usSellPrice      Float?      @default(0)
  regionalPrices   Json?       @default("{}")
  orderItems       OrderItem[]
  proformaInvoiceItems ProformaInvoiceItem[]
}

model Order {
  id                      String      @id @default(uuid())
  userId                  String
  total                   Float
  createdAt               DateTime    @default(now())
  status                  String      @default("PENDING")
  trackingNumber          String?
  courier                 String?
  taxInvoiceIssued        Boolean     @default(false)
  orderNumber             String?     @unique
  depositConfirmedAt      DateTime?
  adminDepositConfirmedAt DateTime?
  user                    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items                   OrderItem[]
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model ProductionBatch {
  id              String   @id @default(uuid())
  category        String
  productionDate  DateTime
  rawMaterialCost Int
  depositDollar   Float?
  electricityCost Int
  packagingCost   Int
  warehouseCost   Int      @default(0)
  shippingCost    Int      @default(0)
  customsFee      Int      @default(0)
  customsDuty     Int      @default(0)
  vat             Int      @default(0)
  quantity        Int
  unitCost        Float?
  salesPrice      Int
  wholesalePrice  Int
  memo            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ElectricityUsage {
  id                String   @id @default(uuid())
  year              Int
  month             Int
  readingDate       String
  usagePeriod       String
  meterCurrent      String
  meterPrevious     String
  totalUsage        Int
  totalAmount       Int
  rawBillData       String
  landlordMeterPrev Int?
  landlordMeterCurr Int?
  landlordUsage     Int?
  waterHeaterKw     Float?
  outdoorLightKw    Float?
  meterPhotoUrl     String?
  rawText           String?
  extractionHistory String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([year, month])
}

model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  fileUrl     String?
  completed   Boolean  @default(false)
  date        DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WormEmailAwbCache {
  id        String   @id @default(uuid())
  uid       String   @unique
  subject   String?
  emailDate DateTime?
  awbNumber String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([updatedAt])
}

model WormOrder {
  id          String   @id @default(uuid())
  orderNumber String   @unique
  receiveDate DateTime
  status      String   @default("DRAFT")
  createdById String?
  remittanceAppliedAt             DateTime?
  remittanceFinalReceiveAmount    Float?
  remittanceFinalReceiveAmountText String?
  remittanceSendAmount            Float?
  remittanceSendAmountText        String?
  remittanceTotalFee              Float?
  remittanceTotalFeeText          String?
  remittanceExchangeRate          Float?
  remittanceExchangeRateText      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([receiveDate])
  @@index([createdAt])
}

model SmsRecipient {
  id          String   @id @default(uuid())
  name        String
  phoneNumber String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
  @@index([updatedAt])
}

model CoupangSyncHistory {
  id           String   @id @default(uuid())
  createdAt    DateTime @default(now())
  itemsFetched Int      @default(0)
  status       String   @default("SUCCESS")
  errorMessage String?
}

model ProformaInvoice {
  id            String                @id @default(uuid())
  invoiceNumber String                @unique
  partnerId     String?
  partnerName   String
  issueDate     DateTime              @default(now())
  totalUsd      Float                 @default(0)
  productionTime String               @default("3-5 days after receiving the deposit")
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  partner       User?                 @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  items         ProformaInvoiceItem[]
}

model ProformaInvoiceItem {
  id                String          @id @default(uuid())
  proformaInvoiceId String
  productId         String?
  productName       String
  productNameEN     String?
  productCode       String?
  quantity          Int
  unitPriceUsd      Float
  amountUsd         Float
  createdAt         DateTime        @default(now())
  proformaInvoice   ProformaInvoice @relation(fields: [proformaInvoiceId], references: [id], onDelete: Cascade)
  product           Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model CardUsage {
  id                    String   @id @default(uuid())
  corpNum               String
  cardNum               String
  useKey                String
  useDT                 String
  usedAt                DateTime?
  approvalType          String?
  approvalNum           String?
  approvalAmount        Int?
  foreignApprovalAmount Float?
  amount                Int?
  tax                   Int?
  serviceCharge         Int?
  totalAmount           Int?
  useStoreNum           String?
  useStoreCorpNum       String?
  useStoreTaxType       Int?
  useStoreName          String?
  useStoreCeo           String?
  useStoreAddr          String?
  useStoreBizType       String?
  useStoreTel           String?
  paymentPlan           String?
  installmentMonths     String?
  currencyCode          String?
  memo                  String?
  userMemo              String?
  category              String?
  reviewedAt            DateTime?
  reviewedBy            String?
  raw                   Json?
  syncedAt              DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([corpNum, cardNum, useKey])
  @@index([usedAt])
  @@index([cardNum])
  @@index([approvalNum])
  @@index([reviewedAt])
}
